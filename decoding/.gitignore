*~

# Mac
.DS_Store

# Model checkpoints (too large for Git)
checkpoints/*.pth
*.pth

# But keep the directory structure
!checkpoints/.gitkeep

# Results - exclude generated test results
results/test_results/*.json

# Figures - exclude generated plots
figures/*.png
figures/*.jpg
figures/*.pdf
results/figures/

# Smoke test fixture and artifacts (synthetic dataset + checkpoints)
.smoke/

# Logs
*.log

# Data - large files
data/images/
data/baseline/

# Keep splits.json (small, important for reproducibility)
!data/splits.json

# Environment
venv/
env/
.env

# Runtime evaluation manifests/logs
.full_eval/
